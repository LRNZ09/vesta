# Host user/group the containers run as, shared across every service.
# Synology defaults: the first user is UID 1026 and the "users" group is GID 100.
#
# Copy this file to .env (gitignored) and pass it to compose explicitly, e.g.:
#   docker compose --env-file .env -f services/vaultwarden/compose.yaml up -d
# (Compose does not auto-load a repo-root .env for -f services/<svc>/compose.yaml.)
#
# Used by `user: "${UID}:${GID}"` (adguardhome, vaultwarden, whoami) and by
# jlesage's USER_ID/GROUP_ID (jdownloader-2). Traefik intentionally runs as root.
UID=1026
GID=100
